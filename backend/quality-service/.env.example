# AVA Photo Quality Checker - Environment Configuration

# Python Service Configuration
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_PORT=5001
FLASK_HOST=0.0.0.0

# Quality Service URL (for Node.js integration)
QUALITY_SERVICE_URL=http://localhost:5001

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=10
UPLOAD_FOLDER=/tmp/ava_uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,heic

# Quality Thresholds (Optional - overrides defaults)
# Uncomment to customize
# MIN_RESOLUTION_WIDTH=800
# MIN_RESOLUTION_HEIGHT=600
# MIN_BLUR_THRESHOLD=100
# IDEAL_BLUR_THRESHOLD=500
# MIN_BRIGHTNESS=50
# MAX_BRIGHTNESS=200

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/app/logs/quality_service.log

# Performance Configuration
MAX_WORKERS=4
TIMEOUT_SECONDS=30

# CORS Configuration (if needed)
CORS_ORIGINS=http://localhost:3000,https://ava-inspec.com

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30

# Redis Configuration (for caching - optional)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# CACHE_EXPIRY_SECONDS=3600

# AWS S3 Configuration (if storing results)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=ava-quality-results

# Database Configuration (if storing quality logs)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ava_insurance
# DB_USER=ava_user
# DB_PASSWORD=secure_password

# Monitoring & Alerting
# SENTRY_DSN=your_sentry_dsn
# ENABLE_METRICS=true
# METRICS_PORT=9090