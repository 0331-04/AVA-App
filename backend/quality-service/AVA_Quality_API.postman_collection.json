{
  "info": {
    "name": "AVA Image Quality API",
    "description": "API collection for testing AVA Image Quality Checker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5001",
      "type": "string"
    },
    {
      "key": "backend_url",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Python Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "response": []
        },
        {
          "name": "Check Single Image Quality",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/your/image.jpg",
                  "description": "Upload vehicle image"
                },
                {
                  "key": "photo_type",
                  "value": "front",
                  "type": "text",
                  "description": "Type of photo (front, rear, left, right, damage, general)"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/check-quality",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "check-quality"]
            }
          },
          "response": []
        },
        {
          "name": "Batch Check Images",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files[]",
                  "type": "file",
                  "src": "/path/to/image1.jpg"
                },
                {
                  "key": "files[]",
                  "type": "file",
                  "src": "/path/to/image2.jpg"
                },
                {
                  "key": "files[]",
                  "type": "file",
                  "src": "/path/to/image3.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/batch-check",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "batch-check"]
            }
          },
          "response": []
        },
        {
          "name": "Get Quality Standards",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/quality-standards",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "quality-standards"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Node.js Backend",
      "item": [
        {
          "name": "Backend Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backend_url}}/api/quality/health",
              "host": ["{{backend_url}}"],
              "path": ["api", "quality", "health"]
            }
          },
          "response": []
        },
        {
          "name": "Check Single via Backend",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "/path/to/your/image.jpg"
                },
                {
                  "key": "photo_type",
                  "value": "front",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{backend_url}}/api/quality/check-single",
              "host": ["{{backend_url}}"],
              "path": ["api", "quality", "check-single"]
            }
          },
          "response": []
        },
        {
          "name": "Check Batch via Backend",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "src": "/path/to/image1.jpg"
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": "/path/to/image2.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{backend_url}}/api/quality/check-batch",
              "host": ["{{backend_url}}"],
              "path": ["api", "quality", "check-batch"]
            }
          },
          "response": []
        },
        {
          "name": "Validate Claim Photos",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "photos",
                  "type": "file",
                  "src": "/path/to/front.jpg"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "src": "/path/to/rear.jpg"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "src": "/path/to/left.jpg"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "src": "/path/to/right.jpg"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "src": "/path/to/damage.jpg"
                },
                {
                  "key": "photoTypes",
                  "value": "[\"front\", \"rear\", \"left\", \"right\", \"damage\"]",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{backend_url}}/api/quality/validate-claim-photos",
              "host": ["{{backend_url}}"],
              "path": ["api", "quality", "validate-claim-photos"]
            }
          },
          "response": []
        },
        {
          "name": "Get Standards via Backend",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backend_url}}/api/quality/standards",
              "host": ["{{backend_url}}"],
              "path": ["api", "quality", "standards"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Test Cases",
      "item": [
        {
          "name": "Test - Blurry Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has quality data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('passed');",
                  "    pm.expect(jsonData).to.have.property('scores');",
                  "});",
                  "",
                  "pm.test(\"Blur score is low for blurry image\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.scores.blur).to.be.below(0.5);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/blurry_image.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/check-quality",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "check-quality"]
            }
          },
          "response": []
        },
        {
          "name": "Test - Dark Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Brightness score is low for dark image\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.scores.brightness).to.be.below(0.5);",
                  "    pm.expect(jsonData.issues).to.include.something.that.includes('dark');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/dark_image.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/check-quality",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "check-quality"]
            }
          },
          "response": []
        },
        {
          "name": "Test - Low Resolution",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Resolution score is low\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.scores.resolution).to.be.below(0.7);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/lowres_image.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/check-quality",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "check-quality"]
            }
          },
          "response": []
        },
        {
          "name": "Test - Good Quality Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Image passes quality check\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.passed).to.be.true;",
                  "    pm.expect(jsonData.overall_status).to.be.oneOf(['excellent', 'good', 'acceptable']);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/good_quality_image.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/check-quality",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "check-quality"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}